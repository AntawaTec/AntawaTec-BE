# =============================================================================
# Variables de entorno para las Edge Functions en LOCAL.
# Uso:  cp supabase/functions/.env.example supabase/functions/.env
#       supabase functions serve --env-file supabase/functions/.env
# El .env real NO se commitea (.gitignore). En hosted estas vars se setean como
# secrets del proyecto (supabase secrets set). SUPABASE_URL y
# SUPABASE_SERVICE_ROLE_KEY las inyecta el runtime solo; NO van acá.
# =============================================================================

# hotmart-webhook + bank-transfer-approval → provisionTenant(redirectTo).
# Con el template custom de invite (config.toml [auth.email.template.invite])
# queda INERTE para el link del email: el template arma la URL con
# {{ .SiteURL }} + {{ .TokenHash }}. Se mantiene por el flujo stock (si el
# template no está activo, p. ej. hosted antes del paso manual del Dashboard).
ONBOARDING_REDIRECT_URL=http://127.0.0.1:3000/auth/callback

# hotmart-webhook: token compartido que Hotmart manda en cada webhook (auth).
HOTMART_HOTTOK=hottok-local-dev

# notification-dispatch: secret del header x-cron-secret (pg_cron → función).
# En local puede quedar vacío (la función permite invocación directa sin secret).
CRON_SECRET=

# _shared/whatsappTransport: sandbox de WhatsApp (RUNBOOK 3.8). Con DRY_RUN=true
# (default) no llama a Meta; TOKEN/PHONE_ID solo hacen falta para envío real.
WHATSAPP_DRY_RUN=true
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
